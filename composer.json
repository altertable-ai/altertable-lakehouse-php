{
  "name": "altertable/lakehouse-php",
  "description": "Altertable Lakehouse PHP API Client",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.1",
    "guzzlehttp/guzzle": "^7.9",
    "guzzlehttp/psr7": "^2.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.10",
    "testcontainers/testcontainers-php": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Altertable\\Lakehouse\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Altertable\\Lakehouse\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs"
  }
}
